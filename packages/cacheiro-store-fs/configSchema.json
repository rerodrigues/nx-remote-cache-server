{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["cacheDirectory", "ttlDays", "sweepIntervalHours"],
  "additionalProperties": false,
  "properties": {
    "cacheDirectory": { "type": "string", "description": "Directory where artifacts are stored." },
    "ttlDays": {
      "type": "integer",
      "minimum": 0,
      "description": "Artifact TTL in days. 0 disables expiration."
    },
    "sweepIntervalHours": {
      "type": "integer",
      "minimum": 0,
      "description": "How often to sweep for expired artifacts (hours). 0 disables the sweep."
    }
  }
}
