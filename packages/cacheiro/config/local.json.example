{
  "$schema": "configSchema.json",
  "server": {
    "port": 3000,
    "host": "localhost"
  },
  "auth": {
    "token": "change-me"
  },
  "store": {
    "type": "filesystem",
    "filesystem": {
      "cacheDirectory": "./cache",
      "ttlDays": 7,
      "sweepIntervalHours": 24
    }
  }
}

