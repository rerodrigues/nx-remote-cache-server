{
  "$schema": "configSchema.json",
  "server": {
    "port": 3000,
    "host": "localhost"
  },
  "auth": {
    "token": "change-me"
  },
  "store": {
    "type": "filesystem",
    "filesystem": {
      "cacheDirectory": "./cache",
      "ttlDays": 7,
      "sweepIntervalHours": 24
    }
  }
}

// S3 example:
// {
//   "store": {
//     "type": "s3",
//     "s3": {
//       "bucket": "my-nx-cache",
//       "region": "us-east-1"
//     }
//   }
// }

// S3 via LocalStack (docker compose up local-s3):
// {
//   "store": {
//     "type": "s3",
//     "s3": {
//       "bucket": "my-nx-cache",
//       "region": "us-east-1",
//       "endpoint": "http://localhost:4566",
//       "accessKeyId": "test",
//       "secretAccessKey": "test",
//       "forcePathStyle": true
//     }
//   }
// }

// GCS example:
// {
//   "store": {
//     "type": "gcs",
//     "gcs": {
//       "bucket": "my-nx-cache"
//     }
//   }
// }

// GCS via fake-gcs-server (docker compose up local-gcs):
// {
//   "store": {
//     "type": "gcs",
//     "gcs": {
//       "bucket": "my-nx-cache",
//       "endpoint": "http://localhost:4443"
//     }
//   }
// }

