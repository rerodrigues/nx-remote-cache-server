{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "host": {
          "type": "string"
        },
        "bodyLimitMb": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum request body size in megabytes."
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "token": {
          "type": "string",
          "description": "Bearer token required on all requests. Auth is disabled if empty."
        }
      }
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["filesystem"]
        },
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dir": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
