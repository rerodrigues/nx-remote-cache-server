{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "host": {
          "type": "string"
        },
        "bodyLimitMb": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum request body size in megabytes."
        },
        "banner": {
          "type": "boolean",
          "description": "Show startup banner. When false, prints a compact single-line header instead."
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "token": {
          "type": "string",
          "description": "Bearer token required on all requests. Auth is disabled if empty."
        }
      }
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["filesystem", "s3", "gcs"]
        },
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cacheDirectory": {
              "type": "string"
            },
            "ttlDays": {
              "type": "integer",
              "minimum": 0,
              "description": "Artifact TTL in days. 0 disables expiration."
            },
            "sweepIntervalHours": {
              "type": "integer",
              "minimum": 0,
              "description": "How often to sweep for expired artifacts (hours). 0 disables the sweep."
            }
          }
        },
        "s3": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bucket": { "type": "string", "description": "S3 bucket name." },
            "region": { "type": "string", "description": "AWS region (e.g. us-east-1)." },
            "endpoint": { "type": "string", "description": "Custom S3-compatible endpoint URL." },
            "accessKeyId": { "type": "string", "description": "AWS access key ID." },
            "secretAccessKey": { "type": "string", "description": "AWS secret access key." },
            "forcePathStyle": {
              "type": "boolean",
              "description": "Use path-style URLs. Required for most S3-compatible storage."
            },
            "prefix": { "type": "string", "description": "Key prefix for all cache entries." },
            "encryptionKey": {
              "type": "string",
              "description": "AES-256-CBC encryption key. Encrypts all artifacts at rest."
            }
          }
        },
        "gcs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bucket": { "type": "string", "description": "GCS bucket name." },
            "endpoint": { "type": "string", "description": "Custom GCS-compatible endpoint URL." },
            "prefix": { "type": "string", "description": "Key prefix for all cache entries." },
            "encryptionKey": {
              "type": "string",
              "description": "AES-256-CBC encryption key. Encrypts all artifacts at rest."
            }
          }
        }
      },
      "if": { "properties": { "type": { "const": "filesystem" } } },
      "then": { "required": ["filesystem"] },
      "else": {
        "if": { "properties": { "type": { "const": "s3" } } },
        "then": { "required": ["s3"] },
        "else": {
          "if": { "properties": { "type": { "const": "gcs" } } },
          "then": { "required": ["gcs"] }
        }
      }
    }
  }
}
