{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "host": {
          "type": "string"
        },
        "bodyLimitMb": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum request body size in megabytes."
        },
        "banner": {
          "type": "boolean",
          "description": "Show startup banner. When false, prints a compact single-line header instead."
        },
        "infobox": {
          "type": "boolean",
          "description": "Show the info box with version, URL, and store details."
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "description": "TLS configuration. When present, server serves HTTPS instead of HTTP.",
          "required": ["certFile", "keyFile"],
          "properties": {
            "certFile": {
              "type": "string",
              "description": "Path to PEM certificate file."
            },
            "keyFile": {
              "type": "string",
              "description": "Path to PEM private key file."
            },
            "caFile": {
              "type": "string",
              "description": "Path to CA certificate file (optional)."
            }
          }
        }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "token": {
          "type": "string",
          "description": "Bearer token required on all requests. Auth is disabled if empty."
        }
      }
    },
    "storeOptions": {
      "type": "object",
      "description": "Store-specific config. Shape depends on the store implementation used by the runner."
    }
  }
}
