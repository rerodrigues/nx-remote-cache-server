{
  "$schema": "../../../node_modules/@renatorodrigues/cacheiro/configSchema.json",
  "server": {
    "port": 3000,
    "host": "localhost"
  },
  "auth": {
    "token": "change-me"
  },
  "storeOptions": {
    "cacheDirectory": "./cache",
    "ttlDays": 7,
    "sweepIntervalHours": 24
  }
}

// S3 example — also update src/index.ts to import and use S3Store:
// {
//   "storeOptions": {
//     "bucket": "my-nx-cache",
//     "region": "us-east-1"
//     // optional:
//     // "prefix": "my-project",
//     // "ssoProfile": "my-aws-sso-profile",
//     // "encryptionKey": "my-secret-key",   // client-side AES-256-CBC
//     // "serverSideEncryption": true,        // S3 SSE-S3 (ignored when encryptionKey is set)
//     // "disableChecksum": false
//   }
// }

// S3 via LocalStack (docker compose up local-s3):
// {
//   "storeOptions": {
//     "bucket": "local-nx-cache",
//     "region": "us-east-1",
//     "endpoint": "http://localhost:4566",
//     "accessKeyId": "test",
//     "secretAccessKey": "test",
//     "forcePathStyle": true
//   }
// }

// GCS example — also update src/index.ts to import and use GcsStore:
// {
//   "storeOptions": {
//     "bucket": "my-nx-cache"
//   }
// }

// GCS via fake-gcs-server (docker compose up local-gcs):
// {
//   "storeOptions": {
//     "bucket": "local-nx-cache",
//     "endpoint": "http://localhost:4443"
//   }
// }

// Azure example — also update src/index.ts to import and use AzureStore:
// {
//   "storeOptions": {
//     "container": "my-nx-cache",
//     "accountName": "myazurestorageaccount"
//   }
// }

